ndard-med-styrskena.pdf\"><\/a><\/p>\n<p><a href=\"https:\/\/bellevuesolskydd.se\/wp-content\/uploads\/2023\/07\/BS_Monteringsanvisning_VSE_v2-EJ-FARDIG.pdf\" target=\"_blank\" rel=\"noopener\">Ladda ner Monteringsanvisning<\/a><\/p>\n<p><a href=\"https:\/\/bellevuesolskydd.se\/wp-content\/uploads\/2023\/07\/Tekniskdata-VSE-med-designlist-samt-styrskena.pdf\" target=\"_blank\" rel=\"noopener\">Ladda ner Teknisk data<\/a><\/p>\n<div class=\"et_pb_blurb_description\"><\/div>\n<p>[\/et_pb_toggle][\/et_pb_column][et_pb_column type=&#8221;1_4&#8243; _builder_version=&#8221;4.23&#8243; background_color=&#8221;#ffffff&#8221; custom_padding=&#8221;||48px||false|false&#8221; border_radii=&#8221;on|5px|5px|5px|5px&#8221; border_width_all=&#8221;1px&#8221; border_color_all=&#8221;#E5DFD8&#8243; global_colors_info=&#8221;{}&#8221; custom_padding__hover=&#8221;|||&#8221;][et_pb_image src=&#8221;https:\/\/bellevuesolskydd.se\/wp-content\/uploads\/2023\/07\/a-line-med-dekorlist-oppen.jpg&#8221; title_text=&#8221;a-line-med-dekorlist-oppen&#8221; force_fullwidth=&#8221;on&#8221; _builder_version=&#8221;4.23&#8243; height=&#8221;300px&#8221; height_tablet=&#8221;300px&#8221; height_phone=&#8221;auto&#8221; height_last_edited=&#8221;on|desktop&#8221; locked=&#8221;off&#8221; global_colors_info=&#8221;{}&#8221;][\/et_pb_image][et_pb_toggle title=&#8221;A-line (V-A)&#8221; open_toggle_background_color=&#8221;RGBA(255,255,255,0)&#8221; closed_toggle_background_color=&#8221;RGBA(255,255,255,0)&#8221; icon_color=&#8221;gcid-c2933ceb-9641-4d37-bb1b-61eb067d45cb&#8221; open_icon_color=&#8221;gcid-c2933ceb-9641-4d37-bb1b-61eb067d45cb&#8221; _builder_version=&#8221;4.23&#8243; _module_preset=&#8221;default&#8221; custom_margin=&#8221;-10px||||false|false&#8221; border_width_all=&#8221;0px&#8221; global_colors_info=&#8221;{%22gcid-c2933ceb-9641-4d37-bb1b-61eb067d45cb%22:%91%22icon_color%22,%22open_icon_color%22%93}&#8221;]<\/p>\n<p>A-Line med styrlina \u00e4r en persiennl\u00f6sning till f\u00