equired\" data-field_type=\"text\" data-original_id=\"message\" placeholder=\"Meddelande\"></textarea>\n\t\t\t</p>\n\t\t\t\t\t\t<input type=\"hidden\" value=\"et_contact_proccess\" name=\"et_pb_contactform_submit_14\"/>\n\t\t\t\t\t\t<div class=\"et_contact_bottom_container\">\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t<button type=\"submit\" name=\"et_builder_submit_button\" class=\"et_pb_contact_submit et_pb_button\">Boka hembesök</button>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<input type=\"hidden\" id=\"_wpnonce-et-pb-contact-form-submitted-14\" name=\"_wpnonce-et-pb-contact-form-submitted-14\" value=\"7361ae3f9f\" /><input type=\"hidden\" name=\"_wp_http_referer\" value=\"/wp-json/wp/v2/pages?status=publish&#038;per_page=100&#038;page=1\" />\n\t\t\t\t\t</form>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"et_pb_module et_pb_text et_pb_text_251  et_pb_text_align_left et_pb_bg_layout_dark\">\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<div class=\"et_pb_text_inner\"><h2></h2>\n<p>Vi besvarar er förfrågan inom 2 arbetsdagar</div>\n\t\t\t</div>\n\t\t\t</div>\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t</div>\n\t\t\t\t\n\t\t\t\t\n\t\t\t</div><div class=\"et_pb_section et_pb_section_148 et_pb_with_background et_section_regular\" >\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<div class=\"et_pb_row et_pb_row_212\">\n\t\t\t\t<div class=\"et_pb_column et_pb_column_4_4 et_pb_column_359  et_pb_css_mix_blend_mode_passthrough et-last-child\">\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<div class=\"et_pb_module et_pb_text et_pb_text_252  et_pb_text_align_left et_pb_bg_layout_light\">\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<div class=\"et_pb_text_inner\"><h3 style=\"text-align: center;\">Vanliga frågor om<span> </span>zip screen <span>vertikalmarkis</span></h3></div>\n\t\t\t</div><div class=\"et_pb_module et_pb_accordion et_pb_accordion_7\">\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<div class=\"et_pb_toggle et_pb_module et_pb_accordion_item et_pb_accordion_item_28  et_pb_toggle_open\">\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<h5 class=\"et_pb_toggle_title\">Kan man få måttanpassade Zip screen?</h5>\n\t\t\t\t<div class=\"et_pb_toggle_content clearfix\"><p><span style=\"font-weight: 400;\">Zip screen vertikalmarkis måttanpassas efter dina önskemål.</span></p></div>\n\t\t\t</div><div class=\"et_pb_toggle et_pb_module et_pb_accordion_item et_pb_accordion_item_29  et_pb_toggle_close\">\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<h5 class=\"et_pb_toggle_title\">Erbjuder ni gratis hembesök?</h5>\n\t\t\t\t<div class=\"et_pb_toggle_content clearfix\"><p><span style=\"font-weight: 400;\">Bellevue Solskydd erbjuder ett gratis hembesök av en solskyddsexperter, som ger dig tips och råd kring Zip screen och hur de bäst passar ditt hem och dina önskemål. </span><span style=\"font-weight: 400;\">Kostnadsfritt hembesök erbjuds under förutsättning av Bellevue Solskydd är med genom hela processen, från måttagning till montering. Då har du som kund även fulla garantier, både på produkter och montering.</span><a href=\"https://bellevuesolskydd.se/#hembasok/\"> <span style=\"font-weight: 400;\">Boka ett gratis hembesök!</span></a></p></div>\n\t\t\t</div><div class=\"et_pb_toggle et_pb_module et_pb_accordion_item et_pb_accordion_item_30  et_pb_toggle_close\">\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<h5 class=\"et_pb_toggle_title\">Ingår montering av Zip screen vertikalmarkiser?</h5>\n\t\t\t\t<div class=\"et_pb_toggle_content clearfix\"><p><span style=\"font-weight: 400;\">Vi levererar och monterar måttbeställda Zip screen vertikalmarkiser efter dina önskemål.</span></p></div>\n\t\t\t</div>\n\t\t\t</div>\n\t\t\t</div>\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t</div>\n\t\t\t\t\n\t\t\t\t\n\t\t\t</div><div class=\"et_pb_section et_pb_section_150 et_section_regular\" >\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t<div class=\"et_pb_row et_pb_row_213\">\n\t\t\t\t<div class